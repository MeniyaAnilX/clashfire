rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Accounts collection
    match /accounts/{accountId} {
      // User can only read their own profile document
      allow read: if request.auth != null && request.auth.uid == accountId;
      
      // User can create their own profile document with starting coins of 0
      allow create: if request.auth != null && request.auth.uid == accountId
                    && request.resource.data.coins == 0;
                    
      // User can update their own profile document, subject to strict coin assertion rules
      allow update: if request.auth != null && request.auth.uid == accountId
                    && (
                      // Case A: Rollover of date (Daily Reset)
                      request.resource.data.lastResetDate != resource.data.lastResetDate
                      
                      // Case B: Same day updates, verify coin increments match task completion additions
                      || (
                        request.resource.data.lastResetDate == resource.data.lastResetDate
                        && (
                          // 1. Coins are not modified (e.g. updating profile details, tasks list, referral links)
                          request.resource.data.coins == resource.data.coins
                          
                          // 2. Claiming a daily link task (+5 or +10 diamonds)
                          // MUST add exactly 1 new unique link key to completedLinks
                          || (
                            (request.resource.data.coins == resource.data.coins + 5 || request.resource.data.coins == resource.data.coins + 10)
                            && request.resource.data.completedLinks.keys().hasAll(resource.data.completedLinks.keys())
                            && request.resource.data.completedLinks.keys().size() == resource.data.completedLinks.keys().size() + 1
                          )
                          
                          // 3. Claiming a daily visit task (+5 diamonds)
                          // MUST add exactly 1 new unique visit key to completedDailyVisits
                          || (
                            request.resource.data.coins == resource.data.coins + 5
                            && request.resource.data.completedDailyVisits.keys().hasAll(resource.data.completedDailyVisits.keys())
                            && request.resource.data.completedDailyVisits.keys().size() == resource.data.completedDailyVisits.keys().size() + 1
                          )
                          
                          // 4. Referral commissions claims
                          || (request.resource.data.coins > resource.data.coins && request.resource.data.coins <= resource.data.coins + 10)
                          
                          // 5. Redeeming packages (cost deductions)
                          || request.resource.data.coins == resource.data.coins - 520
                          || request.resource.data.coins == resource.data.coins - 1060
                          || request.resource.data.coins == resource.data.coins - 2180
                          || request.resource.data.coins == resource.data.coins - 5600
                        )
                      )
                    );
    }

    // FF UID Bindings (Lookup map)
    match /ffUidBindings/{hashedFFUid} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Redemptions collection
    match /redemptions/{redemptionId} {
      allow read: if request.auth != null && resource.data.accountId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.accountId == request.auth.uid;
      allow update, delete: if false;
    }

    // Legacy users collection (For migration lookup)
    match /users/{deviceId} {
      allow read, write: if true;
    }

    // Settings (Missions, Daily Visits, Global variables)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
